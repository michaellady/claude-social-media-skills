{
  "comment": "Override any of these in config.local.json (gitignored). The skill reads config.local.json first if present, then falls back to this file.",
  "tiktok_handle": "mikelady",
  "tiktok_profile_url": "https://www.tiktok.com/@mikelady",
  "api_base": "https://open.tiktokapis.com",
  "video_list_endpoint": "/v2/video/list/",
  "user_info_endpoint": "/v2/user/info/",
  "oauth_scopes": [
    "user.info.basic",
    "user.info.stats",
    "video.list"
  ],
  "video_fields": [
    "id",
    "create_time",
    "video_description",
    "title",
    "duration",
    "share_url",
    "view_count",
    "like_count",
    "comment_count",
    "share_count"
  ],
  "window_days": 14,
  "max_posts_per_scrape": 50,
  "delta_window_days": 7,
  "tag_regex": "\\[(opus|lp|gh|bh):([A-Za-z0-9_-]+)\\]",
  "access_token_env": "TIKTOK_ACCESS_TOKEN"
}
